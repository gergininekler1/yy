<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SPK Düzey 1 - Sermaye Piyasası Araçları</title>
    <style>
        :root { --primary: #2563eb; --bg: #f3f4f6; --text: #1f2937; --card-bg: #ffffff; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; line-height: 1.6; }
        .container { max-width: 800px; margin: auto; }
        header { text-align: center; margin-bottom: 30px; }
        
        /* Sekmeler (Tabs) */
        .tabs { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
        .tab-btn { padding: 10px 20px; border: none; background: #e5e7eb; cursor: pointer; border-radius: 8px; font-weight: bold; transition: 0.3s; }
        .tab-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.3); }
        
        /* İçerik Alanları */
        .section { display: none; background: var(--card-bg); padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .section.active { display: block; }
        
        /* Veri Yükleme Alanı */
        textarea { width: 100%; height: 120px; padding: 15px; margin-bottom: 15px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; font-family: monospace; }
        button.load-btn { background: #10b981; color: white; border: none; padding: 12px 20px; cursor: pointer; border-radius: 8px; width: 100%; font-size: 16px; font-weight: bold; transition: 0.3s; }
        button.load-btn:hover { background: #059669; }
        
        /* Flash Kartlar */
        .flashcard-container { perspective: 1000px; width: 100%; height: 300px; margin-bottom: 20px; }
        .flashcard { width: 100%; height: 100%; position: relative; transition: transform 0.6s cubic-bezier(0.4, 0.2, 0.2, 1); transform-style: preserve-3d; cursor: pointer; }
        .flashcard.is-flipped { transform: rotateY(180deg); }
        .card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; align-items: center; justify-content: center; text-align: center; padding: 30px; border-radius: 12px; box-sizing: border-box; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .card-front { background: var(--card-bg); font-size: 1.4em; font-weight: bold; border: 2px solid var(--primary); color: var(--primary); }
        .card-back { background: var(--primary); color: white; transform: rotateY(180deg); font-size: 1.2em; border: 2px solid var(--primary); }
        .card-controls { display: flex; justify-content: space-between; gap: 10px; }
        .card-btn { padding: 10px 20px; background: var(--text); color: white; border: none; border-radius: 8px; cursor: pointer; flex: 1; font-weight: bold; }
        .card-btn:hover { background: #374151; }

        /* Sorular */
        .question-box { margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e5e7eb; }
        .question-text { font-weight: bold; font-size: 1.1em; margin-bottom: 15px; }
        .options { list-style: none; padding: 0; margin: 0; }
        .options li { background: #f9fafb; margin: 8px 0; padding: 12px 15px; border-radius: 8px; cursor: pointer; border: 1px solid #e5e7eb; transition: 0.2s; }
        .options li:hover { background: #f3f4f6; }
        .options li.correct { background: #d1fae5; border-color: #10b981; color: #065f46; pointer-events: none; }
        .options li.wrong { background: #fee2e2; border-color: #ef4444; color: #991b1b; pointer-events: none; }
        .explanation { display: none; margin-top: 10px; padding: 10px; background: #e0f2fe; border-left: 4px solid #0284c7; border-radius: 4px; font-size: 0.9em; }

        /* Özetler */
        .summary-item { margin-bottom: 20px; border-left: 4px solid var(--primary); padding-left: 15px; background: #f8fafc; padding-top: 10px; padding-bottom: 10px; border-radius: 0 8px 8px 0; }
        .summary-item h3 { margin-top: 0; color: var(--primary); }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>📈 SPK Çalışma Platformu</h1>
        <p>Sermaye Piyasası Araçları (Düzey 1)</p>
    </header>

    <div class="tabs">
        <button class="tab-btn active" onclick="openTab('veri')">Veri Yükle</button>
        <button class="tab-btn" onclick="openTab('ozetler')">Özetler</button>
        <button class="tab-btn" onclick="openTab('flashcards')">Flash Kartlar</button>
        <button class="tab-btn" onclick="openTab('sorular')">Sorular</button>
    </div>

    <div id="veri" class="section active">
        <h2>Gemini'den Gelen JSON Verisini Buraya Yapıştır</h2>
        <textarea id="json-input" placeholder='{"ozetler": [...], "kartlar": [...], "sorular": [...]}'></textarea>
        <button class="load-btn" onclick="loadData()">Veriyi Kaydet ve Yükle</button>
        <p id="load-msg" style="color: #10b981; font-weight: bold; display: none; text-align: center;"></p>
    </div>

    <div id="ozetler" class="section">
        <h2>Bölüm Özetleri</h2>
        <div id="ozet-container">Veri yüklenmedi.</div>
    </div>

    <div id="flashcards" class="section">
        <h2>Kavram Kartları</h2>
        <div class="flashcard-container" onclick="flipCard()">
            <div class="flashcard" id="flashcard-el">
                <div class="card-face card-front" id="card-front-text">Kavram</div>
                <div class="card-face card-back" id="card-back-text">Açıklama</div>
            </div>
        </div>
        <div class="card-controls">
            <button class="card-btn" onclick="prevCard()">Önceki</button>
            <span id="card-counter" style="display: flex; align-items: center; font-weight: bold;">0 / 0</span>
            <button class="card-btn" onclick="nextCard()">Sonraki</button>
        </div>
    </div>

    <div id="sorular" class="section">
        <h2>Soru Bankası</h2>
        <div id="soru-container">Veri yüklenmedi.</div>
    </div>
</div>

<script>
    let appData = { ozetler: [], kartlar: [], sorular: [] };
    let currentCardIndex = 0;

    // Sayfa yüklendiğinde LocalStorage'dan veriyi çek
    window.onload = () => {
        const savedData = localStorage.getItem('spkData');
        if (savedData) {
            appData = JSON.parse(savedData);
            document.getElementById('json-input').value = savedData;
            renderAll();
        }
    };

    // Sekme Değiştirme Sistemi
    function openTab(tabId) {
        document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        event.target.classList.add('active');
    }

    // Veriyi Yükleme ve Kaydetme
    function loadData() {
        try {
            const input = document.getElementById('json-input').value;
            appData = JSON.parse(input);
            localStorage.setItem('spkData', JSON.stringify(appData));
            
            const msg = document.getElementById('load-msg');
            msg.innerText = "Veri başarıyla yüklendi! Sekmelerden çalışmaya başlayabilirsin.";
            msg.style.display = "block";
            setTimeout(() => msg.style.display = "none", 3000);
            
            renderAll();
        } catch (e) {
            alert("Geçersiz JSON formatı. Lütfen kopyaladığınız metni kontrol edin.");
        }
    }

    // Tüm İçerikleri Ekrana Çizme
    function renderAll() {
        renderOzetler();
        renderFlashcards();
        renderSorular();
    }

    // Özetleri Oluştur
    function renderOzetler() {
        const container = document.getElementById('ozet-container');
        if (!appData.ozetler || appData.ozetler.length === 0) return container.innerHTML = "Özet bulunamadı.";
        
        container.innerHTML = appData.ozetler.map(ozet => `
            <div class="summary-item">
                <h3>${ozet.baslik}</h3>
                <p>${ozet.icerik}</p>
            </div>
        `).join('');
    }

    // Flash Kartları Oluştur
    function renderFlashcards() {
        if (!appData.kartlar || appData.kartlar.length === 0) return;
        currentCardIndex = 0;
        updateCardUI();
    }

    function updateCardUI() {
        if (appData.kartlar.length === 0) return;
        const card = appData.kartlar[currentCardIndex];
        document.getElementById('card-front-text').innerText = card.kavram;
        document.getElementById('card-back-text').innerText = card.aciklama;
        document.getElementById('card-counter').innerText = `${currentCardIndex + 1} / ${appData.kartlar.length}`;
        document.getElementById('flashcard-el').classList.remove('is-flipped');
    }

    function flipCard() { document.getElementById('flashcard-el').classList.toggle('is-flipped'); }
    function prevCard() { if (currentCardIndex > 0) { currentCardIndex--; updateCardUI(); } }
    function nextCard() { if (currentCardIndex < appData.kartlar.length - 1) { currentCardIndex++; updateCardUI(); } }

    // Soruları Oluştur
    function renderSorular() {
        const container = document.getElementById('soru-container');
        if (!appData.sorular || appData.sorular.length === 0) return container.innerHTML = "Soru bulunamadı.";
        
        container.innerHTML = appData.sorular.map((soru, index) => `
            <div class="question-box">
                <div class="question-text">${index + 1}. ${soru.soru_metni}</div>
                <ul class="options">
                    ${soru.secenekler.map((secenek, i) => `
                        <li onclick="checkAnswer(this, ${index}, ${i})">${secenek}</li>
                    `).join('')}
                </ul>
                <div class="explanation" id="exp-${index}"><strong>Açıklama:</strong> ${soru.aciklama}</div>
            </div>
        `).join('');
    }

    // Cevap Kontrolü
    function checkAnswer(element, soruIndex, secilenIndex) {
        const soru = appData.sorular[soruIndex];
        const optionsList = element.parentElement.children;
        
        // Daha önce cevaplandıysa işlem yapma
        if (element.parentElement.querySelector('.correct')) return;

        for (let i = 0; i < optionsList.length; i++) {
            if (i === soru.dogru_cevap_index) {
                optionsList[i].classList.add('correct');
            }
        }
        
        if (secilenIndex !== soru.dogru_cevap_index) {
            element.classList.add('wrong');
        }
        
        // Açıklamayı göster
        document.getElementById(`exp-${soruIndex}`).style.display = "block";
    }
</script>

</body>
</html>
